# Alice Blue ANT API Configuration
# NEVER commit real credentials to version control

# API Base URLs
ALICE_BLUE_BASE_URL=https://ant.aliceblueonline.com/rest/AliceBlueAPIService/api
ALICE_BLUE_WS_URL=wss://ant.aliceblueonline.com/hydra

# App Config
APP_ENV=development
MOCK_MODE=true

# Feature Flags
ENABLE_CHARTS=true
ENABLE_NOTIFICATIONS=true
ENABLE_BIOMETRICS=true

# Timeouts (ms)
API_TIMEOUT=30000
WS_RECONNECT_DELAY=3000
SESSION_REFRESH_INTERVAL=3600000
